# Home for AI Mobile — Environment Variables
# Copy to .env.local and fill in your values

# Backend API base URL (no trailing slash)
API_BASE_URL=http://localhost:3000

# OpenRouter API key for AI agent calls
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Supabase (optional, if using Supabase backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# EAS / Expo (set in EAS secrets, not here)
# EXPO_APPLE_ID=your@apple.id
# EXPO_APPLE_TEAM_ID=XXXXXXXXXX
# GOOGLE_PLAY_KEY=<path-to-service-account-json>
